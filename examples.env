# Example environment variables for MoE HotSeat v0
# Copy to your own launch script; do not source blindly if you enjoy uptime.

# Text mode tested value
HOTSEAT_TENSOR_LAYERS=18

# Vision mode tested value
# HOTSEAT_TENSOR_LAYERS=16

# Recommended not to set for pure VRAM-first HotSeat testing:
# HSA_XNACK=1
# GGML_CUDA_ENABLE_UNIFIED_MEMORY=1
